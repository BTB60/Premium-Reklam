{
  "version": 2,
  "framework": "nextjs",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.decorapp.az/api",
    "NEXT_PUBLIC_WS_URL": "wss://api.decorapp.az/ws",
    "NEXT_PUBLIC_MINIO_URL": "https://files.decorapp.az"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
